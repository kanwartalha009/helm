APP_NAME=Helm
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=helm
DB_USERNAME=helm
DB_PASSWORD=helm

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=null
REDIS_DB=0
REDIS_CACHE_DB=1

QUEUE_CONNECTION=redis
CACHE_STORE=redis
SESSION_DRIVER=database

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:5173,127.0.0.1:5173
SESSION_DOMAIN=localhost

# Sentry
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Mail (Postmark or Resend recommended per spec §18)
MAIL_MAILER=log
MAIL_FROM_ADDRESS=helm@nova-solution.io
MAIL_FROM_NAME="${APP_NAME}"

# S3 / DO Spaces (Phase 3 attachments)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-central-1
AWS_BUCKET=helm-attachments

# Currency FX
# Default is frankfurter.app — free, no API key, ECB-sourced daily rates,
# supports /{date}?from=&to= and /{from}..{to}?from=&to= range queries.
# (exchangerate.host moved to a paid model in 2024 and is no longer used.)
FX_PROVIDER_URL=https://api.frankfurter.app
FX_TARGET_CURRENCY=USD

# Frontend
FRONTEND_URL=http://localhost:5173

# NOTE on platform credentials:
# Meta / Google / TikTok credentials are stored in the `platform_credentials`
# table and managed at Settings → Platform keys. Only set the env values below
# for first-time bootstrap before the table is populated; the app reads DB first.
META_SYSTEM_USER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
TIKTOK_BC_TOKEN=

# Shopify (per-brand OAuth — these are the app-level settings)
SHOPIFY_APP_KEY=
SHOPIFY_APP_SECRET=
SHOPIFY_APP_SCOPES="read_orders,read_products,read_customers,read_reports"

# --- LLM layer (D-016, ratified 2026-07-10) ---------------------------------
# Keys can also be pasted in the UI: Settings -> Platform keys -> AI / LLM
# (DB rows win over env). Proof step after setup: php artisan llm:diagnose
HELM_LLM_PROVIDER=anthropic          # anthropic | openai
HELM_ANTHROPIC_API_KEY=
HELM_OPENAI_API_KEY=
# Optional overrides:
# HELM_LLM_MODEL_ANTHROPIC=claude-sonnet-4-20250514
# HELM_LLM_MODEL_OPENAI=gpt-4o
# HELM_LLM_MAX_TOKENS=2000
# HELM_LLM_TEMPERATURE=0.4
# HELM_LLM_TIMEOUT=90
